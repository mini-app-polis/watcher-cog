# Service account credentials JSON as a string (not a file path)
GOOGLE_CREDENTIALS_JSON=
# Prefect Cloud API key
PREFECT_API_KEY=
# Prefect Cloud workspace API URL e.g. https://api.prefect.cloud/api/accounts/{id}/workspaces/{id}
PREFECT_API_URL=
# Healthchecks.io ping URL e.g. https://hc-ping.com/your-uuid
HEALTHCHECKS_URL_WATCHER=
# Sentry DSN for error tracking
SENTRY_DSN=
# DEBUG | INFO | WARNING
LOG_LEVEL=INFO

